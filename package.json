{
  "name": "agent-session-canvas",
  "private": true,
  "type": "module",
  "version": "1.2.0",
  "license": "MIT",
  "repository": "https://github.com/stardime-bingo/agent-session-canvas",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "acceptance:canvas": "node scripts/serve-canvas-acceptance.mjs --fixture=canvas",
    "acceptance:prod": "node scripts/serve-canvas-acceptance.mjs --fixture=prod",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs",
    "verify:global": "npm run build && node --test --test-concurrency=1 tests/*.test.mjs",
    "serve": "node server/index.mjs",
    "scan": "node server/scanner.mjs",
    "start": "npm run build && npm run serve"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.4"
  }
}